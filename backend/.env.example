PORT=5000
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
DB_PATH=./data/dsp_real_estate.db
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
# OpenAI API key — required for AI features (brochure analysis, AI assistant, property insights)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Set to true to serve the built React frontend from the backend on port 5000
SERVE_FRONTEND=false
