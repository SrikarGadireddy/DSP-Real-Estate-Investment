PORT=5000
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
DB_PATH=./data/dsp_real_estate.db

# NODE_ENV: set to "production" to serve the built React frontend from Express
NODE_ENV=development

# CORS_ORIGIN: set to your deployment URL in production (e.g. https://your-app.com)
# When NODE_ENV=production the frontend is served from the same origin, so this
# value is used only for external cross-origin requests.
CORS_ORIGIN=http://localhost:3000

# OpenAI API key — required for AI features (brochure analysis, AI assistant, property insights)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Set to "true" to serve the built React frontend from the backend while keeping
# NODE_ENV=development (useful for local production preview).
SERVE_FRONTEND=false
